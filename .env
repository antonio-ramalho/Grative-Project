# .env — coloque na raiz do projeto, FORA da pasta public/
APP_NAME=VetLume
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=base64:chave-aleatoria-gerada-automaticamente

# Banco de dados
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vetlume_db
DB_USERNAME=root
DB_PASSWORD=senha_muito_segura

# E-mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=seu_usuario
MAIL_PASSWORD=sua_senha

# APIs externas
ZAPI_TOKEN=seu_token_aqui
GEMINI_API_KEY=sua_chave_aqui